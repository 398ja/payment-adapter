<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSX} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root level -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <!-- Payment gateway libraries -->
    <logger name="xyz.tcheeric" level="DEBUG"/>
</configuration>

